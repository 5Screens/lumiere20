// Prisma schema for Lumiere V2
// Database: PostgreSQL with multi-schema support

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["data", "core", "configuration", "translations", "audit", "workflow"]
}

// ============================================
// SCHEMA: data
// ============================================

model configuration_items {
  uuid                 String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  description          String?  @db.Text
  ci_type              String   @default("GENERIC") @db.VarChar(50)
  rel_model_uuid       String?  @db.Uuid // Reference to the model CI (for physical CIs)
  rel_status_uuid      String?  @db.Uuid // Reference to workflow status
  extended_core_fields Json?    @db.JsonB
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  model                      configuration_items?            @relation("CiModel", fields: [rel_model_uuid], references: [uuid])
  instances                  configuration_items[]           @relation("CiModel")
  status                     workflow_statuses?              @relation(fields: [rel_status_uuid], references: [uuid])
  tickets                tickets[]
  service_offering_scope rel_service_offerings_cis[]

  @@index([ci_type])
  @@index([rel_status_uuid])
  @@map("configuration_items")
  @@schema("data")
}

model services {
  uuid                 String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  description          String?  @db.Text
  owning_entity_uuid   String?  @db.Uuid
  owned_by_uuid        String?  @db.Uuid
  managed_by_uuid      String?  @db.Uuid
  business_criticality String?  @db.VarChar(50)
  rel_status_uuid      String?  @db.Uuid
  version              String?  @db.VarChar(50)
  operational          String?  @db.VarChar(50)
  legal_regulatory     String?  @db.VarChar(50)
  reputational         String?  @db.VarChar(50)
  financial            String?  @db.VarChar(50)
  comments             String?  @db.Text
  cab_uuid             String?  @db.Uuid
  parent_uuid          String?  @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  owning_entity     entities?           @relation("ServiceOwningEntity", fields: [owning_entity_uuid], references: [uuid])
  owned_by          persons?            @relation("ServiceOwnedBy", fields: [owned_by_uuid], references: [uuid])
  managed_by        persons?            @relation("ServiceManagedBy", fields: [managed_by_uuid], references: [uuid])
  cab               groups?             @relation("ServiceCAB", fields: [cab_uuid], references: [uuid])
  parent            services?           @relation("ServiceParent", fields: [parent_uuid], references: [uuid])
  children          services[]          @relation("ServiceParent")
  status            workflow_statuses?  @relation("ServiceLifecycle", fields: [rel_status_uuid], references: [uuid])
  service_offerings    service_offerings[]
  request_catalog_items request_catalog_items[]
  symptoms              symptoms[]
  causes                causes[]

  @@index([rel_status_uuid])
  @@map("services")
  @@schema("data")
}

model service_offerings {
  uuid                 String    @id @default(uuid()) @db.Uuid
  name                 String    @db.VarChar(255)
  description          String?   @db.Text
  start_date           DateTime  @default(now()) @db.Date
  end_date             DateTime? @db.Date
  business_criticality String?   @db.VarChar(50)
  environment          String?   @db.VarChar(100)
  price_model          String?   @db.VarChar(100)
  currency             String?   @db.VarChar(3)
  service_uuid         String    @db.Uuid
  operator_entity_uuid String    @db.Uuid
  rel_status_uuid      String?   @db.Uuid
  created_at           DateTime  @default(now()) @db.Timestamptz(6)
  updated_at           DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service         services           @relation(fields: [service_uuid], references: [uuid], onDelete: Cascade)
  operator_entity entities           @relation("ServiceOfferingOperator", fields: [operator_entity_uuid], references: [uuid], onDelete: Cascade)
  status          workflow_statuses? @relation("ServiceOfferingLifecycle", fields: [rel_status_uuid], references: [uuid])

  // Reverse relations
  subscriptions   service_offering_subscriptions[]
  sla_commitments sla_commitments[]
  ci_scope        rel_service_offerings_cis[]

  @@index([rel_status_uuid])
  @@map("service_offerings")
  @@schema("data")
}

// Request Catalog Items - Elements that users can request from services
model request_catalog_items {
  uuid             String   @id @default(uuid()) @db.Uuid
  name             String   @db.VarChar(255)
  description      String?  @db.Text
  rel_service_uuid String?  @db.Uuid
  icon             String?  @db.VarChar(50)
  form_fields      Json?    @db.JsonB // Dynamic form fields definition for user input
  is_active        Boolean  @default(true)
  display_order    Int      @default(0)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service services? @relation(fields: [rel_service_uuid], references: [uuid], onDelete: Cascade)

  @@index([rel_service_uuid])
  @@map("request_catalog_items")
  @@schema("data")
}

// User Sets - Define sets of users based on criteria
model user_sets {
  uuid        String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  criteria    Json     @db.JsonB // JSON criteria for filtering users (e.g., {"role": "manager", "language": "fr", "ref_location_uuid": "...", "room": {"$exists": true}})
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Reverse relations
  subscriptions service_offering_subscriptions[]

  @@map("user_sets")
  @@schema("data")
}

// Calendars - Define time schedules (working hours, holidays, etc.)
model calendars {
  uuid        String   @id @default(uuid()) @db.Uuid
  name        String   @db.VarChar(255)
  description String?  @db.Text
  timezone    String   @db.VarChar(100) // e.g., 'Europe/Paris', 'UTC'
  parent_uuid String?  @db.Uuid // Reference to parent calendar (e.g., CEST for SUPPORT_WORKING_HOURS)
  schedule    Json     @db.JsonB // Weekly schedule: {"monday": [{"start": "09:00", "end": "18:00"}], ...}
  holidays    Json?    @db.JsonB // List of holidays: [{"date": "2026-01-01", "name": "New Year"}, ...]
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  parent   calendars?  @relation("CalendarParent", fields: [parent_uuid], references: [uuid])
  children calendars[] @relation("CalendarParent")

  // Reverse relations
  sla_definitions sla_definitions[]

  @@map("calendars")
  @@schema("data")
}

// SLA Definitions - Define SLA templates with targets
model sla_definitions {
  uuid              String   @id @default(uuid()) @db.Uuid
  name              String   @db.VarChar(255)
  description       String?  @db.Text
  metric_type       String   @db.VarChar(50) // 'resolution_time', 'response_time', 'availability', etc.
  priority_code     String?  @db.VarChar(50) // P1, P2, P3, P4 or null for all priorities
  target_value      Float // Target value (e.g., 2 for 2 hours, 99.9 for 99.9% availability)
  target_unit       String   @db.VarChar(20) // 'hours', 'minutes', 'days', 'percent'
  target_percentage Float    @default(100) // Percentage of cases that must meet the target (e.g., 80 for 80%)
  rel_calendar_uuid String   @db.Uuid // Calendar to use for time calculations
  is_active         Boolean  @default(true)
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  calendar calendars @relation(fields: [rel_calendar_uuid], references: [uuid])

  // Reverse relations
  commitments sla_commitments[]

  @@map("sla_definitions")
  @@schema("data")
}

// SLA Commitments - Link SLA definitions to service offerings
model sla_commitments {
  uuid                      String    @id @default(uuid()) @db.Uuid
  rel_service_offering_uuid String    @db.Uuid
  rel_sla_definition_uuid   String    @db.Uuid
  start_date                DateTime  @default(now()) @db.Date
  end_date                  DateTime? @db.Date
  is_active                 Boolean   @default(true)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service_offering service_offerings @relation(fields: [rel_service_offering_uuid], references: [uuid], onDelete: Cascade)
  sla_definition   sla_definitions   @relation(fields: [rel_sla_definition_uuid], references: [uuid], onDelete: Cascade)

  @@unique([rel_service_offering_uuid, rel_sla_definition_uuid])
  @@map("sla_commitments")
  @@schema("data")
}

// Service Offering Subscriptions - Link offerings to user_sets, locations, entities, groups
model service_offering_subscriptions {
  uuid                      String    @id @default(uuid()) @db.Uuid
  rel_service_offering_uuid String    @db.Uuid
  subscriber_type           String    @db.VarChar(50) // 'user_set', 'location', 'entity', 'group'
  rel_user_set_uuid         String?   @db.Uuid
  rel_location_uuid         String?   @db.Uuid
  rel_entity_uuid           String?   @db.Uuid
  rel_group_uuid            String?   @db.Uuid
  start_date                DateTime  @default(now()) @db.Date
  end_date                  DateTime? @db.Date
  is_active                 Boolean   @default(true)
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service_offering service_offerings @relation(fields: [rel_service_offering_uuid], references: [uuid], onDelete: Cascade)
  user_set         user_sets?        @relation(fields: [rel_user_set_uuid], references: [uuid], onDelete: Cascade)
  location         locations?        @relation(fields: [rel_location_uuid], references: [uuid], onDelete: Cascade)
  entity           entities?         @relation(fields: [rel_entity_uuid], references: [uuid], onDelete: Cascade)
  group            groups?           @relation(fields: [rel_group_uuid], references: [uuid], onDelete: Cascade)

  @@index([rel_service_offering_uuid])
  @@index([subscriber_type])
  @@map("service_offering_subscriptions")
  @@schema("data")
}

// Relation: Service Offerings to Configuration Items (CI scope)
model rel_service_offerings_cis {
  uuid                      String    @id @default(uuid()) @db.Uuid
  rel_service_offering_uuid String    @db.Uuid
  rel_ci_uuid               String    @db.Uuid
  relationship_type         String?   @db.VarChar(50) // 'includes', 'supports', 'requires', etc.
  start_date                DateTime  @default(now()) @db.Date
  end_date                  DateTime? @db.Date
  created_at                DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service_offering   service_offerings   @relation(fields: [rel_service_offering_uuid], references: [uuid], onDelete: Cascade)
  configuration_item configuration_items @relation(fields: [rel_ci_uuid], references: [uuid], onDelete: Cascade)

  @@unique([rel_service_offering_uuid, rel_ci_uuid])
  @@index([rel_service_offering_uuid])
  @@index([rel_ci_uuid])
  @@map("rel_service_offerings_cis")
  @@schema("data")
}

// ============================================
// SCHEMA: configuration
// ============================================

// CI Categories - Categories for grouping CI Types
model ci_categories {
  uuid          String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(50) // Unique code for programmatic access
  label         String   @db.VarChar(255) // Default label (fallback if no translation)
  icon          String?  @db.VarChar(50) // PrimeVue icon class
  display_order Int      @default(0) // Order in menu
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ci_types ci_types[]

  @@map("ci_categories")
  @@schema("configuration")
}

// CI Types - Types of Configuration Items
model ci_types {
  uuid                      String   @id @default(uuid()) @db.Uuid
  code                      String   @unique @db.VarChar(50)
  label                     String   @db.VarChar(255) // Default label (fallback if no translation)
  description               String?  @db.Text // Default description (fallback if no translation)
  icon                      String?  @db.VarChar(50)
  color                     String?  @db.VarChar(20)
  is_active                 Boolean  @default(true)
  display_order             Int      @default(0)
  has_model                 Boolean  @default(true) // If true, CIs of this type can have a model reference
  is_model_for_ci_type_code String?  @db.VarChar(50) // For model types: the CI type code this is a model for
  rel_category_uuid         String?  @db.Uuid // Relation to category (will be required after migration)
  created_at                DateTime @default(now()) @db.Timestamptz(6)
  updated_at                DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  category ci_categories?   @relation(fields: [rel_category_uuid], references: [uuid])
  fields   ci_type_fields[]

  @@index([rel_category_uuid])
  @@index([is_model_for_ci_type_code])
  @@map("ci_types")
  @@schema("configuration")
}

// CI Type Fields - Extended fields definition for each CI type
// These fields define what attributes are stored in configuration_items.extended_core_fields
model ci_type_fields {
  uuid         String  @id @default(uuid()) @db.Uuid
  ci_type_uuid String  @db.Uuid
  field_name   String  @db.VarChar(100) // Field key in extended_core_fields JSON
  label        String  @db.VarChar(255) // Default label (translations in translated_fields)
  description  String? @db.VarChar(500) // Default description (translations in translated_fields)
  field_type   String  @db.VarChar(50) // text, number, boolean, date, datetime, select, multiselect
  data_type    String  @default("string") @db.VarChar(50) // string, number, boolean, date, array

  // Display options
  show_in_table Boolean @default(false) // Show in DataTable
  show_in_form  Boolean @default(true) // Show in create/edit form
  is_required   Boolean @default(false)
  is_readonly   Boolean @default(false)

  // Column display
  min_width     String? @db.VarChar(20) // e.g., '10rem', '150px'
  display_order Int     @default(0) // Order in form

  // Validation
  max_length    Int?
  min_value     Float?
  max_value     Float?
  pattern       String? @db.VarChar(255) // Regex pattern for validation
  default_value String? @db.VarChar(255) // Default value for the field

  // Select options
  options_source String? @db.Text // JSON array of options or API endpoint

  // Relation options (for field_type = 'relation')
  relation_object  String? @db.VarChar(100) // Related object type (e.g., 'configuration_items', 'persons')
  relation_display String? @db.VarChar(100) // Field to display from related object
  relation_filter  Json?   @db.JsonB // Filter for relation (e.g., { "ci_type": "SERVICE" })

  // Formatting
  format_pattern String? @db.VarChar(100) // Date format, number format, etc.
  unit           String? @db.VarChar(20) // Unit suffix (e.g., 'GB', 'VA', 'Gbps')

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ci_type ci_types @relation(fields: [ci_type_uuid], references: [uuid], onDelete: Cascade)

  @@unique([ci_type_uuid, field_name])
  @@index([ci_type_uuid, display_order])
  @@map("ci_type_fields")
  @@schema("configuration")
}

model ticket_types {
  uuid       String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(50)
  label      String   @db.VarChar(100)
  icon       String?  @db.VarChar(50) // PrimeVue icon class (e.g., 'pi-exclamation-triangle')
  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ticket_status ticket_status[]
  tickets       tickets[]
  fields        ticket_type_fields[]

  @@map("ticket_types")
  @@schema("configuration")
}

// Ticket Type Fields - Extended fields definition for each ticket type
// These fields define what attributes are stored in tickets.extended_core_fields
model ticket_type_fields {
  uuid             String  @id @default(uuid()) @db.Uuid
  ticket_type_uuid String  @db.Uuid
  field_name       String  @db.VarChar(100) // Field key in extended_core_fields JSON
  label            String  @db.VarChar(255) // Default label (translations in translated_fields)
  description      String? @db.VarChar(500) // Default description (translations in translated_fields)
  field_type       String  @db.VarChar(50) // text, number, boolean, date, datetime, select, multiselect, textarea, relation
  data_type        String  @default("string") @db.VarChar(50) // string, number, boolean, date, array

  // Display options
  show_in_table Boolean @default(false) // Show in DataTable
  show_in_form  Boolean @default(true) // Show in create/edit form
  is_required   Boolean @default(false)
  is_readonly   Boolean @default(false)

  // Column display
  min_width     String? @db.VarChar(20) // e.g., '10rem', '150px'
  display_order Int     @default(0) // Order in form

  // Validation
  max_length    Int?
  min_value     Float?
  max_value     Float?
  pattern       String? @db.VarChar(255) // Regex pattern for validation
  default_value String? @db.VarChar(255) // Default value for the field

  // Select options
  options_source String? @db.Text // JSON array of options or API endpoint

  // Relation options (for field_type = 'relation')
  relation_object  String? @db.VarChar(100) // Related object type (e.g., 'services', 'persons', 'tickets', 'configuration_items')
  relation_display String? @db.VarChar(100) // Field to display from related object
  relation_filter  Json?   @db.JsonB // Filter for relation (e.g., { "ticket_type_code": "PROJECT" } or { "ci_type_code": "SERVICE" })

  // Formatting
  format_pattern String? @db.VarChar(100) // Date format, number format, etc.
  unit           String? @db.VarChar(20) // Unit suffix (e.g., 'hours', 'days')

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ticket_type ticket_types @relation(fields: [ticket_type_uuid], references: [uuid], onDelete: Cascade)

  @@unique([ticket_type_uuid, field_name])
  @@index([ticket_type_uuid, display_order])
  @@map("ticket_type_fields")
  @@schema("configuration")
}

model ticket_status {
  uuid            String   @id @default(uuid()) @db.Uuid
  code            String   @db.VarChar(50)
  rel_ticket_type String?  @db.VarChar(50)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ticket_type ticket_types? @relation(fields: [rel_ticket_type], references: [code])
  locations   locations[]

  @@unique([code, rel_ticket_type])
  @@map("ticket_status")
  @@schema("configuration")
}

model symptoms {
  uuid             String   @id @default(uuid()) @db.Uuid
  code             String   @unique @db.VarChar(50)
  label            String   @db.VarChar(255) // Default label (translations in translated_fields)
  rel_service_uuid String?  @db.Uuid
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service services? @relation(fields: [rel_service_uuid], references: [uuid], onDelete: Cascade)

  @@index([rel_service_uuid])
  @@map("symptoms")
  @@schema("configuration")
}

// Cause Catalog - Root causes for incidents/problems
model causes {
  uuid             String   @id @default(uuid()) @db.Uuid
  code             String   @unique @db.VarChar(50)
  label            String   @db.VarChar(255) // Default label (translations in translated_fields)
  rel_service_uuid String?  @db.Uuid
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now()) @db.Timestamptz(6)
  updated_at       DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  service services? @relation(fields: [rel_service_uuid], references: [uuid], onDelete: Cascade)

  @@index([rel_service_uuid])
  @@map("causes")
  @@schema("configuration")
}

model entities {
  uuid                      String   @id @default(uuid()) @db.Uuid
  name                      String   @db.VarChar(255)
  entity_id                 String   @unique @db.VarChar(50)
  external_id               String?  @db.VarChar(100)
  entity_type               String   @db.VarChar(50)
  budget_approver_uuid      String?  @db.Uuid
  rel_headquarters_location String?  @db.Uuid
  is_active                 Boolean  @default(true)
  parent_uuid               String?  @db.Uuid
  created_at                DateTime @default(now()) @db.Timestamptz(6)
  updated_at                DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  budget_approver       persons?   @relation("EntityBudgetApprover", fields: [budget_approver_uuid], references: [uuid])
  headquarters_location locations? @relation("EntityHeadquarters", fields: [rel_headquarters_location], references: [uuid])
  parent                entities?  @relation("EntityParent", fields: [parent_uuid], references: [uuid])
  children              entities[] @relation("EntityParent")

  // Reverse relations
  persons                        persons[]                        @relation("PersonEntity")
  services_owned                 services[]                       @relation("ServiceOwningEntity")
  service_offerings              service_offerings[]              @relation("ServiceOfferingOperator")
  locations_primary              locations[]                      @relation("LocationPrimaryEntity")
  rel_entities_locations         rel_entities_locations[]
  rel_persons_entities           rel_persons_entities[]
  service_offering_subscriptions service_offering_subscriptions[]

  @@map("entities")
  @@schema("configuration")
}

model locations {
  uuid                       String    @id @default(uuid()) @db.Uuid
  name                       String    @db.VarChar(255)
  primary_entity_uuid        String?   @db.Uuid
  field_service_group_uuid   String?   @db.Uuid
  rel_status_uuid            String?   @db.Uuid
  site_created_on            DateTime? @db.Timestamptz(6)
  site_id                    String?   @db.VarChar(100)
  type                       String?   @db.VarChar(100)
  business_criticality       String?   @db.VarChar(50)
  opening_hours              String?   @db.VarChar(255)
  parent_uuid                String?   @db.Uuid
  phone                      String?   @db.VarChar(50)
  time_zone                  String?   @db.VarChar(100)
  street                     String?   @db.VarChar(255)
  city                       String?   @db.VarChar(255)
  state_province             String?   @db.VarChar(255)
  country                    String?   @db.VarChar(100)
  postal_code                String?   @db.VarChar(20)
  comments                   String?   @db.Text
  alternative_site_reference String?   @db.VarChar(255)
  wan_design                 String?   @db.Text
  network_telecom_service    String?   @db.Text
  created_at                 DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  primary_entity      entities?      @relation("LocationPrimaryEntity", fields: [primary_entity_uuid], references: [uuid])
  field_service_group groups?        @relation("LocationFieldServiceGroup", fields: [field_service_group_uuid], references: [uuid])
  rel_status          ticket_status? @relation(fields: [rel_status_uuid], references: [uuid])
  parent              locations?     @relation("LocationParent", fields: [parent_uuid], references: [uuid])
  children            locations[]    @relation("LocationParent")

  // Reverse relations
  persons                        persons[]                        @relation("PersonLocation")
  entities_headquarters          entities[]                       @relation("EntityHeadquarters")
  rel_entities_locations         rel_entities_locations[]
  service_offering_subscriptions service_offering_subscriptions[]

  @@map("locations")
  @@schema("configuration")
}

model persons {
  uuid                       String    @id @default(uuid()) @db.Uuid
  first_name                 String    @db.VarChar(100)
  last_name                  String    @db.VarChar(100)
  job_role                   String?   @db.VarChar(255)
  ref_entity_uuid            String?   @db.Uuid
  password_hash              String?   @db.VarChar(255)
  password_needs_reset       Boolean   @default(false)
  locked_out                 Boolean   @default(false)
  is_active                  Boolean   @default(true)
  critical_user              Boolean   @default(false)
  external_user              Boolean   @default(false)
  date_format                String?   @db.VarChar(50)
  internal_id                String?   @db.VarChar(100)
  email                      String    @unique @db.VarChar(255)
  notification               Boolean   @default(true)
  time_zone                  String?   @db.VarChar(100)
  ref_location_uuid          String?   @db.Uuid
  floor                      String?   @db.VarChar(50)
  room                       String?   @db.VarChar(50)
  ref_approving_manager_uuid String?   @db.Uuid
  phone                      String?   @db.VarChar(50)
  business_phone             String?   @db.VarChar(50)
  business_mobile_phone      String?   @db.VarChar(50)
  personal_mobile_phone      String?   @db.VarChar(50)
  language                   String?   @db.VarChar(10)
  role                       String    @default("user") @db.VarChar(50)
  roles                      Json?     @db.JsonB
  photo                      String?   @db.Text
  last_login                 DateTime? @db.Timestamptz(6)
  created_at                 DateTime  @default(now()) @db.Timestamptz(6)
  updated_at                 DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  ref_entity            entities?  @relation("PersonEntity", fields: [ref_entity_uuid], references: [uuid])
  ref_location          locations? @relation("PersonLocation", fields: [ref_location_uuid], references: [uuid])
  ref_approving_manager persons?   @relation("PersonApprovingManager", fields: [ref_approving_manager_uuid], references: [uuid])
  subordinates          persons[]  @relation("PersonApprovingManager")

  // Reverse relations
  entities_budget_approver       entities[]              @relation("EntityBudgetApprover")
  services_owned_by              services[]              @relation("ServiceOwnedBy")
  services_managed_by            services[]              @relation("ServiceManagedBy")
  groups_supervisor              groups[]                @relation("GroupSupervisor")
  groups_manager                 groups[]                @relation("GroupManager")
  tickets_requested_by           tickets[]               @relation("TicketRequestedBy")
  tickets_requested_for          tickets[]               @relation("TicketRequestedFor")
  tickets_writer                 tickets[]               @relation("TicketWriter")
  rel_persons_groups             rel_persons_groups[]
  rel_persons_delegates_person   rel_persons_delegates[] @relation("DelegatePerson")
  rel_persons_delegates_delegate rel_persons_delegates[] @relation("DelegateDelegate")
  rel_persons_entities           rel_persons_entities[]
  audit_changes                  audit_changes[]         @relation("AuditUser")
  tickets_assigned               tickets[]               @relation("TicketAssignedPerson")
  attachments_uploaded           attachments[]
  agent_conversations            agent_conversations[]

  @@map("persons")
  @@schema("configuration")
}

model groups {
  uuid           String   @id @default(uuid()) @db.Uuid
  group_name     String   @db.VarChar(255)
  support_level  Int?
  description    String?  @db.Text
  rel_supervisor String?  @db.Uuid
  rel_manager    String?  @db.Uuid
  rel_schedule   String?  @db.Uuid
  email          String?  @db.VarChar(255)
  phone          String?  @db.VarChar(50)
  created_at     DateTime @default(now()) @db.Timestamptz(6)
  updated_at     DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  supervisor persons? @relation("GroupSupervisor", fields: [rel_supervisor], references: [uuid])
  manager    persons? @relation("GroupManager", fields: [rel_manager], references: [uuid])

  // Reverse relations
  services_cab                   services[]                       @relation("ServiceCAB")
  locations_field_service        locations[]                      @relation("LocationFieldServiceGroup")
  rel_persons_groups             rel_persons_groups[]
  tickets_assigned               tickets[]                        @relation("TicketAssignedGroup")
  service_offering_subscriptions service_offering_subscriptions[]

  @@map("groups")
  @@schema("configuration")
}

// Junction tables
model rel_persons_groups {
  uuid       String   @id @default(uuid()) @db.Uuid
  rel_member String   @db.Uuid
  rel_group  String   @db.Uuid
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  member persons @relation(fields: [rel_member], references: [uuid], onDelete: Cascade)
  group  groups  @relation(fields: [rel_group], references: [uuid], onDelete: Cascade)

  @@unique([rel_member, rel_group])
  @@map("rel_persons_groups")
  @@schema("configuration")
}

model rel_persons_delegates {
  uuid          String    @id @default(uuid()) @db.Uuid
  person_uuid   String    @db.Uuid
  delegate_uuid String    @db.Uuid
  start_date    DateTime  @db.Date
  end_date      DateTime? @db.Date
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  person   persons @relation("DelegatePerson", fields: [person_uuid], references: [uuid], onDelete: Cascade)
  delegate persons @relation("DelegateDelegate", fields: [delegate_uuid], references: [uuid], onDelete: Cascade)

  @@map("rel_persons_delegates")
  @@schema("configuration")
}

model rel_entities_locations {
  uuid          String    @id @default(uuid()) @db.Uuid
  entity_uuid   String    @db.Uuid
  location_uuid String    @db.Uuid
  start_date    DateTime  @default(now()) @db.Date
  end_date      DateTime? @db.Date
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
  updated_at    DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  entity   entities  @relation(fields: [entity_uuid], references: [uuid], onDelete: Cascade)
  location locations @relation(fields: [location_uuid], references: [uuid], onDelete: Cascade)

  @@map("rel_entities_locations")
  @@schema("configuration")
}

model rel_persons_entities {
  uuid        String   @id @default(uuid()) @db.Uuid
  person_uuid String   @db.Uuid
  entity_uuid String   @db.Uuid
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  person persons  @relation(fields: [person_uuid], references: [uuid], onDelete: Restrict)
  entity entities @relation(fields: [entity_uuid], references: [uuid], onDelete: Restrict)

  @@unique([person_uuid, entity_uuid])
  @@map("rel_persons_entities")
  @@schema("configuration")
}

// ============================================
// SCHEMA: core
// ============================================

model tickets {
  uuid                    String    @id @default(uuid()) @db.Uuid
  title                   String    @db.VarChar(255)
  description             String?   @db.Text
  configuration_item_uuid String?   @db.Uuid
  requested_by_uuid       String?   @db.Uuid
  requested_for_uuid      String?   @db.Uuid
  writer_uuid             String    @db.Uuid
  ticket_type_code        String    @db.VarChar(50)
  rel_status_uuid         String?   @db.Uuid
  assigned_group_uuid     String?   @db.Uuid
  assigned_person_uuid    String?   @db.Uuid
  watchers                Json?     @db.JsonB
  extended_core_fields    Json?     @db.JsonB
  created_at              DateTime  @default(now()) @db.Timestamptz(6)
  updated_at              DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  closed_at               DateTime? @db.Timestamptz(6)

  // Relations
  configuration_item configuration_items? @relation(fields: [configuration_item_uuid], references: [uuid], onDelete: Restrict)
  requested_by       persons?             @relation("TicketRequestedBy", fields: [requested_by_uuid], references: [uuid], onDelete: Restrict)
  requested_for      persons?             @relation("TicketRequestedFor", fields: [requested_for_uuid], references: [uuid], onDelete: Restrict)
  writer             persons              @relation("TicketWriter", fields: [writer_uuid], references: [uuid], onDelete: Restrict)
  ticket_type        ticket_types         @relation(fields: [ticket_type_code], references: [code], onDelete: Restrict)
  status             workflow_statuses?   @relation(fields: [rel_status_uuid], references: [uuid], onDelete: Restrict)
  assigned_group     groups?              @relation("TicketAssignedGroup", fields: [assigned_group_uuid], references: [uuid], onDelete: SetNull)
  assigned_person    persons?             @relation("TicketAssignedPerson", fields: [assigned_person_uuid], references: [uuid], onDelete: SetNull)

  // Parent/child relations
  parent_relations rel_parent_child_tickets[] @relation("TicketParent")
  child_relations  rel_parent_child_tickets[] @relation("TicketChild")
  // Note: attachments are linked via entity_type='tickets' + entity_uuid (polymorphic, no FK)

  @@map("tickets")
  @@schema("core")
}

model attachments {
  uuid             String   @id @default(uuid()) @db.Uuid
  entity_type      String   @db.VarChar(50) // 'tickets', 'agent_conversation', etc.
  entity_uuid      String   @db.Uuid // UUID of the related entity (not a FK - polymorphic)
  file_name        String   @db.VarChar(255)
  original_name    String   @db.VarChar(255)
  mime_type        String   @db.VarChar(100)
  file_size        Int
  file_path        String   @db.VarChar(500)
  uploaded_by_uuid String   @db.Uuid
  created_at       DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  uploaded_by persons @relation(fields: [uploaded_by_uuid], references: [uuid], onDelete: Restrict)
  // Note: entity_uuid is polymorphic (can reference tickets, agent_conversations, etc.)
  // No FK constraint - the relation is managed by entity_type + entity_uuid

  @@index([entity_type, entity_uuid])
  @@map("attachments")
  @@schema("core")
}

model rel_parent_child_tickets {
  uuid                   String    @id @default(uuid()) @db.Uuid
  rel_parent_ticket_uuid String    @db.Uuid
  rel_child_ticket_uuid  String    @db.Uuid
  dependency_code        String    @db.VarChar(50)
  created_at             DateTime  @default(now()) @db.Timestamptz(6)
  updated_at             DateTime  @default(now()) @updatedAt @db.Timestamptz(6)
  ended_at               DateTime? @db.Timestamptz(6)

  parent_ticket tickets @relation("TicketParent", fields: [rel_parent_ticket_uuid], references: [uuid], onDelete: Cascade)
  child_ticket  tickets @relation("TicketChild", fields: [rel_child_ticket_uuid], references: [uuid], onDelete: Cascade)

  @@map("rel_parent_child_tickets")
  @@schema("core")
}

// Agent Conversations - Stores chat conversations with the AI agent
model agent_conversations {
  uuid       String   @id @default(uuid()) @db.Uuid
  user_uuid  String   @db.Uuid
  title      String?  @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  messages agent_messages[]
  user     persons          @relation(fields: [user_uuid], references: [uuid], onDelete: Cascade)

  @@index([user_uuid])
  @@map("agent_conversations")
  @@schema("core")
}

// Agent Messages - Individual messages within a conversation
model agent_messages {
  uuid              String   @id @default(uuid()) @db.Uuid
  conversation_uuid String   @db.Uuid
  role              String   @db.VarChar(20) // 'user', 'assistant', 'tool'
  content           String?  @db.Text
  tool_calls        Json?    @db.JsonB // If assistant requests tool calls
  tool_call_id      String?  @db.VarChar(100) // If role = 'tool', the tool call ID
  tool_name         String?  @db.VarChar(100) // If role = 'tool', the tool name
  feedback          String?  @db.VarChar(10) // 'up', 'down', or null
  created_at        DateTime @default(now()) @db.Timestamptz(6)

  conversation agent_conversations @relation(fields: [conversation_uuid], references: [uuid], onDelete: Cascade)

  @@index([conversation_uuid])
  @@map("agent_messages")
  @@schema("core")
}

// ============================================
// SCHEMA: translations
// ============================================

// Generic translations table (single table for all entities) for any entity with translatable fields
// Single table for all entities: ci_types, ticket_status, symptoms, etc.
model translated_fields {
  uuid        String   @id @default(uuid()) @db.Uuid
  entity_type String   @db.VarChar(100) // 'ci_types', 'ticket_status', 'symptoms', etc.
  entity_uuid String   @db.Uuid // UUID of the translated entity
  field_name  String   @db.VarChar(100) // 'label', 'description', etc.
  locale      String   @db.VarChar(10) // 'fr', 'en', 'es', 'pt', 'de', 'zh', etc.
  value       String   @db.Text // The translated value
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([entity_type, entity_uuid, field_name, locale])
  @@index([entity_type, entity_uuid])
  @@index([locale])
  @@map("translated_fields")
  @@schema("translations")
}

// ============================================
// SCHEMA: configuration - Languages
// ============================================

// Languages table for multi-language support
model languages {
  uuid       String   @id @default(uuid()) @db.Uuid
  code       String   @unique @db.VarChar(10) // ISO 639-1 code (e.g., 'fr', 'en', 'es')
  name       String   @db.VarChar(100) // Native name (e.g., 'Français', 'English')
  name_en    String   @db.VarChar(100) // English name (e.g., 'French', 'English')
  flag_code  String   @db.VarChar(10) // Flag code for icons (e.g., 'fr', 'gb')
  is_active  Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("languages")
  @@schema("configuration")
}

// ============================================
// SCHEMA: configuration - Object Metadata
// ============================================

// Stores metadata about object types (tables) for dynamic UI generation
model object_types {
  uuid               String  @id @default(uuid()) @db.Uuid
  code               String  @unique @db.VarChar(100) // e.g., 'entities', 'locations', 'groups', 'persons'
  label_key          String  @db.VarChar(100) // i18n key for the object type label
  icon               String? @db.VarChar(50) // PrimeVue icon class (for menu/sidebar)
  api_endpoint       String  @db.VarChar(255) // API endpoint path
  default_sort_field String  @default("updated_at") @db.VarChar(100)
  default_sort_order Int     @default(-1) // 1 = asc, -1 = desc

  // Relation display settings (used when this object is a relation target)
  display_field   String? @db.VarChar(100) // Primary field to display (e.g., 'label', 'name', 'title')
  secondary_field String? @db.VarChar(100) // Secondary field to display (e.g., 'code', 'email')

  is_active  Boolean  @default(true)
  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  fields object_fields[]

  @@map("object_types")
  @@schema("configuration")
}

// Stores metadata about fields (columns) for each object type
model object_fields {
  uuid             String @id @default(uuid()) @db.Uuid
  object_type_uuid String @db.Uuid
  field_name       String @db.VarChar(100) // Database column name
  label_key        String @db.VarChar(100) // i18n key for the field label
  field_type       String @db.VarChar(50) // text, number, boolean, date, datetime, select, relation
  data_type        String @default("string") @db.VarChar(50) // string, number, boolean, date

  // Display options
  show_in_table   Boolean @default(true) // Show in DataTable
  show_in_form    Boolean @default(true) // Show in create/edit form
  show_in_detail  Boolean @default(true) // Show in detail view
  is_sortable     Boolean @default(true)
  is_filterable   Boolean @default(true)
  is_editable     Boolean @default(true) // Allow inline editing
  is_required     Boolean @default(false)
  is_readonly     Boolean @default(false)
  is_translatable Boolean @default(false) // Field supports dynamic translations

  // Column display
  min_width       String? @db.VarChar(20) // e.g., '10rem', '150px'
  default_visible Boolean @default(true) // Visible by default in table
  display_order   Int     @default(0) // Order in table/form

  // Validation
  max_length Int?
  min_value  Float?
  max_value  Float?
  pattern    String? @db.VarChar(255) // Regex pattern for validation

  // Select/Relation options
  options_source   String? @db.Text // For select: static options JSON or API endpoint
  relation_object  String? @db.VarChar(100) // For relation: target object type code
  relation_display String? @db.VarChar(100) // For relation: field to display (e.g., 'name')
  relation_filter  String? @db.Text // For relation: JSON filter (e.g., '{"is_active":true}')

  // Formatting
  format_pattern String? @db.VarChar(100) // Date format, number format, etc.

  created_at DateTime @default(now()) @db.Timestamptz(6)
  updated_at DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  object_type object_types @relation(fields: [object_type_uuid], references: [uuid], onDelete: Cascade)

  @@unique([object_type_uuid, field_name])
  @@index([object_type_uuid, display_order])
  @@map("object_fields")
  @@schema("configuration")
}

// Object Setup - Generic configuration for business objects metadata
// Replaces: entity_setup_codes, incident_setup_codes, problem_categories, defect_setup_codes, project_setup_codes, knowledge_setup_codes
model object_setup {
  uuid          String   @id @default(uuid()) @db.Uuid
  object_type   String   @db.VarChar(50) // 'entity', 'incident', 'problem', 'defect', 'project', 'knowledge', 'change', 'person', 'contact'
  metadata      String   @db.VarChar(50) // 'CATEGORY', 'URGENCY', 'IMPACT', 'SEVERITY', 'VISIBILITY', 'CAUSE_CODE', 'RESOLUTION_CODE', etc.
  code          String   @db.VarChar(50) // 'COMPANY', 'CRITICAL', 'BLOCKER', etc. (also used as fallback label)
  value         Int? // Optional numeric value (for priority levels, ordering)
  icon          String?  @db.VarChar(50) // PrimeVue icon class (e.g., 'pi-building', 'pi-exclamation-triangle')
  color         String?  @db.VarChar(50) // Tag style / color (e.g., 'success', 'danger', '#FF5733')
  font_weight   String?  @db.VarChar(20) // 'normal', 'bold', 'semibold'
  font_style    String?  @db.VarChar(20) // 'normal', 'italic'
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@unique([object_type, metadata, code])
  @@index([object_type, metadata])
  @@index([object_type])
  @@map("object_setup")
  @@schema("configuration")
}

// ============================================
// SCHEMA: workflow
// ============================================

// Workflow status categories (Backlog, In Progress, On Hold, Done)
model workflow_status_categories {
  uuid          String   @id @default(uuid()) @db.Uuid
  code          String   @unique @db.VarChar(50) // BACKLOG, IN_PROGRESS, ON_HOLD, DONE
  color         String   @db.VarChar(20) // Hex color code
  display_order Int      @default(0)
  is_active     Boolean  @default(true)
  created_at    DateTime @default(now()) @db.Timestamptz(6)
  updated_at    DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  statuses workflow_statuses[]

  @@map("workflow_status_categories")
  @@schema("workflow")
}

// Workflows - define lifecycle for entity types
model workflows {
  uuid                 String   @id @default(uuid()) @db.Uuid
  name                 String   @db.VarChar(255)
  description          String?  @db.Text
  entity_type          String   @db.VarChar(100) // 'ci_types', 'ticket_types', 'persons', 'locations', etc.
  rel_entity_type_uuid String?  @db.Uuid // Optional: UUID of specific type (e.g., ci_type "SERVER")
  is_active            Boolean  @default(true)
  created_at           DateTime @default(now()) @db.Timestamptz(6)
  updated_at           DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  statuses    workflow_statuses[]
  transitions workflow_transitions[]

  @@index([entity_type])
  @@index([rel_entity_type_uuid])
  @@map("workflows")
  @@schema("workflow")
}

// Workflow statuses - states in a workflow
model workflow_statuses {
  uuid              String   @id @default(uuid()) @db.Uuid
  rel_workflow_uuid String   @db.Uuid
  name              String   @db.VarChar(60) // Max 60 characters as per spec
  rel_category_uuid String   @db.Uuid
  allow_all_inbound Boolean  @default(true) // "Accessible depuis n'importe quel état"
  is_initial        Boolean  @default(false) // Initial state of the workflow
  position_x        Float    @default(0) // X coordinate on canvas
  position_y        Float    @default(0) // Y coordinate on canvas
  created_at        DateTime @default(now()) @db.Timestamptz(6)
  updated_at        DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  workflow workflows                  @relation(fields: [rel_workflow_uuid], references: [uuid], onDelete: Cascade)
  category workflow_status_categories @relation(fields: [rel_category_uuid], references: [uuid], onDelete: Restrict)

  // Reverse relations
  transitions_to      workflow_transitions[]        @relation("TransitionTo")
  transition_sources  workflow_transition_sources[]
  configuration_items configuration_items[]
  tickets             tickets[]
  services            services[]                    @relation("ServiceLifecycle")
  service_offerings   service_offerings[]           @relation("ServiceOfferingLifecycle")

  @@index([rel_workflow_uuid])
  @@index([rel_category_uuid])
  @@map("workflow_statuses")
  @@schema("workflow")
}

// Workflow transitions - connections between statuses
model workflow_transitions {
  uuid               String   @id @default(uuid()) @db.Uuid
  rel_workflow_uuid  String   @db.Uuid
  name               String   @db.VarChar(255) // Transition label (e.g., "Start work", "Cancel")
  rel_to_status_uuid String   @db.Uuid // Destination status (unique)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  updated_at         DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  workflow  workflows         @relation(fields: [rel_workflow_uuid], references: [uuid], onDelete: Cascade)
  to_status workflow_statuses @relation("TransitionTo", fields: [rel_to_status_uuid], references: [uuid], onDelete: Cascade)

  // Reverse relations
  sources workflow_transition_sources[]

  @@index([rel_workflow_uuid])
  @@index([rel_to_status_uuid])
  @@map("workflow_transitions")
  @@schema("workflow")
}

// Workflow transition sources - multiple source statuses per transition
model workflow_transition_sources {
  uuid                 String   @id @default(uuid()) @db.Uuid
  rel_transition_uuid  String   @db.Uuid
  rel_from_status_uuid String   @db.Uuid
  created_at           DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  transition  workflow_transitions @relation(fields: [rel_transition_uuid], references: [uuid], onDelete: Cascade)
  from_status workflow_statuses    @relation(fields: [rel_from_status_uuid], references: [uuid], onDelete: Cascade)

  @@unique([rel_transition_uuid, rel_from_status_uuid])
  @@index([rel_transition_uuid])
  @@index([rel_from_status_uuid])
  @@map("workflow_transition_sources")
  @@schema("workflow")
}

// Workflow entity configuration - defines how workflows map to entity subtypes
// This table allows the system to know which field determines the subtype for each entity type
model workflow_entity_config {
  uuid                String   @id @default(uuid()) @db.Uuid
  entity_type         String   @unique @db.VarChar(100) // 'configuration_items', 'tickets', 'persons', 'locations'
  subtype_field       String   @db.VarChar(100) // Field in the entity that determines subtype: 'ci_type', 'ticket_type_code', 'role'
  subtype_table       String?  @db.VarChar(100) // Prisma table name for subtypes: 'ci_types', 'ticket_types', null (if enum)
  subtype_uuid_field  String?  @db.VarChar(100) // UUID field in subtype table: 'uuid'
  subtype_code_field  String?  @db.VarChar(100) // Code field in subtype table: 'code' (used to link entity to subtype)
  subtype_label_field String?  @db.VarChar(100) // Label field in subtype table: 'label', 'code'
  subtype_options     Json?    @db.JsonB // Static options if no table: ['admin', 'user', 'manager']
  description         String?  @db.Text
  is_active           Boolean  @default(true)
  created_at          DateTime @default(now()) @db.Timestamptz(6)
  updated_at          DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  @@map("workflow_entity_config")
  @@schema("workflow")
}

// ============================================
// SCHEMA: audit
// ============================================

// Audit changes table for logging all modifications in the system
model audit_changes {
  uuid           String   @id @default(uuid()) @db.Uuid
  object_type    String   @db.VarChar(50) // Type of object: 'persons', 'locations', 'entities', etc.
  object_uuid    String   @db.Uuid // UUID of the modified object
  event_type     String   @db.VarChar(50) // Event type: 'Obj_CREATED', 'Field_UPDATED', 'Password_RESET', etc.
  attribute_name String?  @db.VarChar(255) // Name of the modified field, NULL if event concerns the whole object
  old_value      String?  @db.Text // Value before modification, NULL for creations
  new_value      String?  @db.Text // Value after modification, NULL for deletions
  rel_user_uuid  String   @db.Uuid // UUID of the user who made the modification
  event_date     DateTime @default(now()) @db.Timestamptz(6)

  // Relations
  user persons @relation("AuditUser", fields: [rel_user_uuid], references: [uuid], onDelete: Restrict)

  @@index([object_uuid])
  @@index([rel_user_uuid])
  @@index([event_date])
  @@index([event_type])
  @@index([object_type])
  @@map("audit_changes")
  @@schema("audit")
}

// ============================================
// SCHEMA: core - Portals
// ============================================

model portals {
  uuid                  String   @id @default(uuid()) @db.Uuid
  code                  String   @unique @db.VarChar(50)
  name                  String   @db.VarChar(255)
  base_url              String?  @db.VarChar(500)
  is_active             Boolean  @default(false)
  view_component        String?  @db.VarChar(100)
  title                 String?  @db.VarChar(255)
  subtitle              String?  @db.VarChar(255)
  welcome_template      String?  @db.VarChar(500)
  logo_url              String?  @db.VarChar(500)
  theme_primary_color   String?  @db.VarChar(20)
  theme_secondary_color String?  @db.VarChar(20)
  show_chat             Boolean  @default(false)
  show_alerts           Boolean  @default(false)
  show_actions          Boolean  @default(false)
  show_widgets          Boolean  @default(false)
  chat_default_message  String?  @db.VarChar(500)
  created_at            DateTime @default(now()) @db.Timestamptz(6)
  updated_at            DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  // Relations
  portal_actions portal_portal_actions[]
  portal_alerts  portal_portal_alerts[]
  portal_widgets portal_portal_widgets[]

  @@map("portals")
  @@schema("core")
}

model portal_actions {
  uuid        String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  label       String   @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(100)
  action_type String?  @db.VarChar(50)
  action_url  String?  @db.VarChar(500)
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  portals portal_portal_actions[]

  @@map("portal_actions")
  @@schema("core")
}

model portal_alerts {
  uuid       String    @id @default(uuid()) @db.Uuid
  code       String    @unique @db.VarChar(50)
  message    String    @db.Text
  severity   String?   @db.VarChar(20)
  icon       String?   @db.VarChar(100)
  is_active  Boolean   @default(true)
  start_date DateTime? @db.Timestamptz(6)
  end_date   DateTime? @db.Timestamptz(6)
  created_at DateTime  @default(now()) @db.Timestamptz(6)
  updated_at DateTime  @default(now()) @updatedAt @db.Timestamptz(6)

  portals portal_portal_alerts[]

  @@map("portal_alerts")
  @@schema("core")
}

model portal_widgets {
  uuid        String   @id @default(uuid()) @db.Uuid
  code        String   @unique @db.VarChar(50)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(100)
  widget_type String?  @db.VarChar(50)
  config      Json?    @db.JsonB
  is_active   Boolean  @default(true)
  created_at  DateTime @default(now()) @db.Timestamptz(6)
  updated_at  DateTime @default(now()) @updatedAt @db.Timestamptz(6)

  portals portal_portal_widgets[]

  @@map("portal_widgets")
  @@schema("core")
}

// Junction tables
model portal_portal_actions {
  rel_portal        String @db.Uuid
  rel_portal_action String @db.Uuid
  display_order     Int    @default(0)

  portal portals        @relation(fields: [rel_portal], references: [uuid], onDelete: Cascade)
  action portal_actions @relation(fields: [rel_portal_action], references: [uuid], onDelete: Cascade)

  @@id([rel_portal, rel_portal_action])
  @@map("portal__portal_actions")
  @@schema("core")
}

model portal_portal_alerts {
  rel_portal       String @db.Uuid
  rel_portal_alert String @db.Uuid
  display_order    Int    @default(0)

  portal portals       @relation(fields: [rel_portal], references: [uuid], onDelete: Cascade)
  alert  portal_alerts @relation(fields: [rel_portal_alert], references: [uuid], onDelete: Cascade)

  @@id([rel_portal, rel_portal_alert])
  @@map("portal__portal_alerts")
  @@schema("core")
}

model portal_portal_widgets {
  rel_portal        String @db.Uuid
  rel_portal_widget String @db.Uuid
  display_order     Int    @default(0)

  portal portals        @relation(fields: [rel_portal], references: [uuid], onDelete: Cascade)
  widget portal_widgets @relation(fields: [rel_portal_widget], references: [uuid], onDelete: Cascade)

  @@id([rel_portal, rel_portal_widget])
  @@map("portal__portal_widgets")
  @@schema("core")
}
