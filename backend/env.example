# Backend Environment Variables Example
# Copy this file to .env and update with your actual values

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=lumiere_db
DB_USER=postgres
DB_PASSWORD=your_password_here
DB_SSL=false

# Optional Database Parameters
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT=30000

# Upload Configuration
UPLOAD_DIR=C:\storage\l16
MAX_FILE_SIZE=10485760
ALLOWED_FILE_TYPES=
FORBIDDEN_FILE_TYPES=application/x-msdownload,application/x-executable,application/javascript,application/x-php,text/x-php

# AI Agent Configuration
INFOMANIAK_AI_API_URL=https://api.infomaniak.com/1/ai/YOUR_PRODUCT_ID/openai/chat/completions
INFOMANIAK_AI_TOKEN=your_api_token_here
INFOMANIAK_AI_MODEL=mixtral

# Prisma Database URL
# See: https://pris.ly/d/connection-strings
DATABASE_URL="prisma+postgres://localhost:51255/?api_key=your_api_key_here"

# Server Configuration
PORT=3000
NODE_ENV=development

# Logging
LOG_LEVEL=info
